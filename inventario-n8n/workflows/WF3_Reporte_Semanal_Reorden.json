{
  "name": "WF3_Reporte_Semanal_Reorden",
  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    p.sku,\n    p.nombre,\n    p.stock_actual,\n    p.stock_minimo,\n    COALESCE(SUM(v.cantidad), 0) AS ventas_semana\nFROM productos p\nLEFT JOIN ventas v\n    ON p.sku = v.sku\n    AND v.fecha >= NOW() - INTERVAL '7 days'\nGROUP BY p.sku, p.nombre, p.stock_actual, p.stock_minimo\nORDER BY p.sku;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
