          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const sku = item.json.sku;\n  const nombre = item.json.nombre;\n  const stockActual = Number(item.json.stock_actual || 0);\n  const stockMinimo = Number(item.json.stock_minimo || 0);\n  const ventasSemana = Number(item.json.ventas_semana || 0);\n\n  let sugerenciaReorden = (ventasSemana + stockMinimo) - stockActual;\n  if (sugerenciaReorden < 0) {\n    sugerenciaReorden = 0;\n  }\n\n  let estado = \"NORMAL\";\n  if (stockActual <= stockMinimo) {\n    estado = \"BAJO_STOCK\";\n  }\n\n  return {\n    json: {\n      sku,\n      nombre,\n      stock_actual: stockActual,\n      stock_minimo: stockMinimo,\n      ventas_semana: ventasSemana,\n      sugerencia_reorden: sugerenciaReorden,\n      estado\n    }\n  };\n});"
      },
